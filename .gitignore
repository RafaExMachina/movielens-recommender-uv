# ============================================================
# Dados gerados ou pesados
# ============================================================

/data/raw/*
/data/interim/*
/data/processed/*
/data/features/*

!/data/raw/.gitignore
!/data/raw/*.dvc

!/data/raw/.gitkeep
!/data/interim/.gitkeep
!/data/processed/.gitkeep
!/data/features/.gitkeep

